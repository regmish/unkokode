{
  "manifest_version": 3,
  "name": "Live Nepali Unicode Input",
  "description": "Type romanized Nepali and transliterate completed words into Nepali Unicode on the web.",
  "version": "0.1.0",
  "permissions": ["storage", "commands"],
  "host_permissions": ["<all_urls>"],
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_title": "Nepali Typing",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png"
    }
  },
  "options_page": "options.html",
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "commands": {
    "toggle-nepali-mode": {
      "suggested_key": {
        "default": "Alt+Shift+N"
      },
      "description": "Toggle Nepali transliteration mode for the current tab"
    }
  }
}
